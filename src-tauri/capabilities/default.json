{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for VoltEnv",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries",
          "cmd": "*",
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "http:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$TEMP/**" }
      ]
    }
  ]
}
