{
  "productName": "VoltEnv",
  "version": "0.1.0",
  "identifier": "com.voltenv.app",
  "build": {
    "beforeDevCommand": "bun --cwd src-frontend dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun --cwd src-frontend generate",
    "frontendDist": "../src-frontend/.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "VoltEnv",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}