{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for VoltEnv production plugins",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "fs:default",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$RESOURCE/**"
        },
        {
          "path": "$TEMP/**"
        }
      ]
    },
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "https://*"
        }
      ]
    },
    "os:default",
    "log:default",
    "store:default"
  ]
}